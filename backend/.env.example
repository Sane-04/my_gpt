# PostgreSQL 数据库名，Docker Compose 中 postgres 容器会读取该值初始化数据库。
POSTGRES_DB=my_gpt

# PostgreSQL 用户名。
POSTGRES_USER=postgres

# PostgreSQL 密码，生产环境必须替换为强随机密码。
POSTGRES_PASSWORD=change-me

# 数据库连接地址；Docker Compose 部署时主机名使用 postgres，本地开发可改为 127.0.0.1。
DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/my_gpt

# JWT 签名密钥，生产环境必须替换为高强度随机字符串。
JWT_SECRET=change-me

# JWT 登录态有效天数。
JWT_EXPIRE_DAYS=7

# 允许跨域访问后端的前端来源；多个来源使用 JSON 数组格式。
CORS_ORIGINS=["https://cyandsane.bond","http://cyandsane.bond","https://localhost","http://localhost","capacitor://localhost","http://localhost:5173","http://127.0.0.1:5173"]

# 聊天模型服务的 API Key，使用官方 OpenAI 或兼容服务时填写。
OPENAI_API_KEY=

# 聊天模型服务的基础地址，官方 OpenAI 默认为 https://api.openai.com/v1。
OPENAI_BASE_URL=https://api.openai.com/v1

# 聊天模型 API 协议，可选值需与后端模型客户端支持范围一致。
OPENAI_API_PROTOCOL=chat_completions

# 主要对话模型名称。
RESPONSES_MODEL=gpt-5.4

# 图片生成模型名称，Image API 使用。
IMAGE_MODEL=gpt-image-2

# 图片默认尺寸。
IMAGE_SIZE=1024x1024

# 图片请求质量；中转站可能按实际套餐降级，后端会记录实际返回值。
IMAGE_QUALITY=high

# 图片输出格式。
IMAGE_OUTPUT_FORMAT=png

# 图片意图识别读取的最近消息数量。
IMAGE_INTENT_CONTEXT_SIZE=5

# 文本向量模型名称，用于长期记忆检索等 embedding 场景。
EMBEDDING_MODEL=text-embedding-3-small

# 构造上下文时读取的最近消息窗口大小。
CONTEXT_WINDOW_SIZE=5

# 长期记忆文本允许注入提示词的最大字符数。
LONG_TERM_MEMORY_MAX_CHARS=20000

# 是否保存提示词快照，调试提示词问题时可改为 true。
SAVE_PROMPT_SNAPSHOTS=false

# 长期记忆 Markdown 文件存储目录。
MEMORY_DIR=backend/data/memories

# Embedding 服务的 API Key；为空时可按后端配置回退到聊天模型 Key。
EMBEDDING_API_KEY=

# Embedding 服务基础地址，官方 OpenAI 默认为 https://api.openai.com/v1。
EMBEDDING_BASE_URL=https://api.openai.com/v1

# SerpApi API Key，用于联网搜索工具。
SERPAPI_API_KEY=

# 聊天联网搜索提供商，可选 serpapi 或 grok；默认使用 serpapi 保持兼容。
WEB_SEARCH_PROVIDER=serpapi

# SerpApi 请求超时时间，避免服务器网络不通时聊天一直处于生成中。
SERPAPI_TIMEOUT_SECONDS=15

# Grok 搜索 API Key；独立于普通聊天模型配置，仅用于聊天 web_search 工具。
GROK_API_KEY=

# Grok 搜索 API 地址，xAI 官方默认为 https://api.x.ai/v1。
GROK_BASE_URL=https://api.x.ai/v1

# Grok 搜索模型名称。
GROK_SEARCH_MODEL=grok-4.3

# Grok 搜索请求超时时间。
GROK_SEARCH_TIMEOUT_SECONDS=60

# Grok 搜索来源数量上限。
GROK_SEARCH_MAX_RESULTS=5

# 非流式模型请求超时时间，用于 embedding 等普通 HTTP 调用。
MODEL_HTTP_TIMEOUT_SECONDS=60

# 图像生成和图像编辑请求超时时间，单位秒。
IMAGE_HTTP_TIMEOUT_SECONDS=360

# 流式模型读取超时时间；上游长时间无数据时会结束并返回可读错误。
MODEL_STREAM_TIMEOUT_SECONDS=180
